# Used only when running `npm run check` locally to test scripts/check.mjs.
# The deployed GitHub Actions workflow does NOT read this file - it uses
# GitHub Secrets instead (see README "Deployment").

# --- AI research (Anthropic Claude) ---
ANTHROPIC_API_KEY=""

# Optional. Defaults to claude-haiku-4-5 (cheap - questions here are simple
# Yes/No lookups, not deep research, so a small model is plenty).
ANTHROPIC_MODEL="claude-haiku-4-5"

# --- Email (Gmail SMTP) ---
# See README "Email configuration" for how to create an App Password.
GMAIL_ADDRESS=""
GMAIL_APP_PASSWORD=""
EMAIL_FROM_NAME="Question Watcher"
